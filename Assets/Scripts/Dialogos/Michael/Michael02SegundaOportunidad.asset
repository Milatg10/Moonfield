  m_Script: {fileID: 11500000, guid: aed0cbf9d3d3e894497ae68cadb2dd0c, type: 3}
  m_Name: Michael02SegundaOportunidad
  m_EditorClassIdentifier: Assembly-CSharp::NodoDialogo
  nombreNPC: Michael
  colorNombre: {r: 0.1176471, g: 0.5647059, b: 1, a: 1}
  textoDelNPC: "Sin m\xE1s, aburrido como siempre. Si no tienes nada jugoso que contarme,
    estoy ocupado mirando por esa ventana a ver qu\xE9 hace la vecina."
  respuestas:
  - textoBoton: "Venga, solo dime el c\xF3digo del cofre, es urgente."
    siguienteNodo: {fileID: 11400000, guid: 2c35c555ca199d94e97e18e37b1a91ea, type: 2}
    cambioAmistad: 0
  - textoBoton: Espera, te cuento un secreto de la ciudad si me ayudas.
    siguienteNodo: {fileID: 11400000, guid: 62ed055bc6d4ab64c821e9e220c9b8fc, type: 2}
    cambioAmistad: 0
  - textoBoton: Pff, odio a los chismosos.
    siguienteNodo: {fileID: 11400000, guid: 2c35c555ca199d94e97e18e37b1a91ea, type: 2}
    cambioAmistad: 0
